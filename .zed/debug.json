// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
    "label": "Debug DCSSimpleLauncher",
    "adapter": "netcoredbg",
    "request": "launch",
    "program": "$ZED_WORKTREE_ROOT/bin/x64/Debug/net10.0-windows10.0.22621.0/DCSSimpleLauncher.dll",
    "cwd": "$ZED_WORKTREE_ROOT",
    "build": {
      "command": "dotnet",
      "args": [
        "build",
        "$ZED_WORKTREE_ROOT/DCSSimpleLauncher.csproj",
        "/property:GenerateFullPaths=true",
        "/property:Platform=x64",
        "/consoleloggerparameters:NoSummary",
      ],
    },
  },
]
