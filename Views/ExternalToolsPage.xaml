<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DCSSimpleLauncher.Views.ExternalToolsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DCSSimpleLauncher.Views"
    xmlns:data="using:DCSSimpleLauncher.Data"
    xmlns:helper="using:DCSSimpleLauncher.Helper"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Orientation="Vertical" Margin="20">
        <TextBlock Text="External Tools" Style="{StaticResource TitleTextBlockStyle}" />
        <Button HorizontalAlignment="Right" x:Name="AddElement" Content="Add External Tool" Margin="0,20,0,0" Click="AddElement_Click"/>
        <ListView x:Name="ToolsListView" Margin="0,10,0,0" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="data:CompanionApp">
                    <Grid Padding="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" Source="{x:Bind helper:IconHelper.GetIcon(Path), Mode=OneWay}" Width="32" Height="32" Margin="0,0,8,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Name}" FontWeight="Bold"/>
                            <TextBlock Text="{x:Bind Path}" Opacity="0.7" FontSize="12"/>
                        </StackPanel>
                        <SplitButton Grid.Column="2" Content="{x:Bind helper:ToolStateHelper.GetLabel(IsRunning), Mode=OneWay}" Click="LaunchTool_Click" Margin="4,0">
                            <SplitButton.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Kill" Tag="{x:Bind}" IsEnabled="{x:Bind IsRunning, Mode=OneWay}" Click="KillTool_Click"/>
                                </MenuFlyout>
                            </SplitButton.Flyout>
                        </SplitButton>
                        <Button Grid.Column="3" Content="Edit" Click="EditTool_Click" Margin="4,0"/>
                        <Button Grid.Column="4" Click="DeleteTool_Click" Margin="4,0" Background="#C42B1C" Foreground="White" ToolTipService.ToolTip="Delete">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#D33B2C"/>
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#A81C10"/>
                                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White"/>
                            </Button.Resources>
                            <FontIcon Glyph="&#xE74D;"/>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </StackPanel>
</Page>
